default_platform(:ios)

XCODEPROJ = "CodeDump.xcodeproj"
SCHEME    = "CodeDump"

platform :ios do

  # ── Testing ────────────────────────────────────────────

  desc "Run unit tests"
  lane :test do
    # CodeDumpUITests are intentionally skipped: they assert against a
    # specific seed/UI flow that has drifted from the current app and
    # need their own PR to repair. Unit tests gate CI for now.
    run_tests(
      project: XCODEPROJ,
      scheme: SCHEME,
      devices: ["iPhone 16 Pro"],
      code_coverage: true,
      result_bundle: true,
      output_directory: "./build/test_output",
      clean: true,
      ensure_devices_found: false,
      skip_testing: ["CodeDumpUITests"]
    )
  end

  # ── Shared CI setup ──────────────────────────────────────

  private_lane :ci_signing_xcargs do
    require "base64"
    api_key_path = File.join(Dir.tmpdir, "AuthKey_#{ENV['APP_STORE_CONNECT_KEY_ID']}.p8")
    File.write(api_key_path, Base64.decode64(ENV["APP_STORE_CONNECT_KEY"]))

    [
      "-allowProvisioningUpdates",
      "-authenticationKeyPath '#{api_key_path}'",
      "-authenticationKeyID '#{ENV['APP_STORE_CONNECT_KEY_ID']}'",
      "-authenticationKeyIssuerID '#{ENV['APP_STORE_CONNECT_ISSUER_ID']}'"
    ].join(" ")
  end

  # ── Beta (TestFlight) ─────────────────────────────────

  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci if is_ci

    if is_ci
      import_certificate(
        certificate_path: ENV["CERTIFICATE_PATH"],
        certificate_password: ENV["P12_PASSWORD"],
        keychain_name: "fastlane_tmp_keychain",
        keychain_password: ""
      )
    end

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_KEY"],
      is_key_content_base64: true
    )

    current = latest_testflight_build_number(api_key: api_key)
    increment_build_number(
      build_number: current + 1,
      xcodeproj: XCODEPROJ
    )

    sigh(
      api_key: api_key,
      app_identifier: "com.Solomon.Lazer-Dragon",
      readonly: true
    ) if is_ci

    signing_args = is_ci ? ci_signing_xcargs : ""
    archive_path = "./build/LazerDragon.xcarchive"

    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      clean: true,
      xcargs: signing_args,
      skip_package_ipa: true,
      archive_path: archive_path
    )

    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      export_method: "app-store",
      output_directory: "./build",
      archive_path: archive_path,
      skip_build_archive: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  # ── Release (App Store) ──────────────────────────────

  desc "Build and submit to App Store review"
  lane :release do
    setup_ci if is_ci

    if is_ci
      import_certificate(
        certificate_path: ENV["CERTIFICATE_PATH"],
        certificate_password: ENV["P12_PASSWORD"],
        keychain_name: "fastlane_tmp_keychain",
        keychain_password: ""
      )
    end

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_KEY"],
      is_key_content_base64: true
    )

    current = latest_testflight_build_number(api_key: api_key)
    increment_build_number(
      build_number: current + 1,
      xcodeproj: XCODEPROJ
    )

    sigh(
      api_key: api_key,
      app_identifier: "com.Solomon.Lazer-Dragon",
      readonly: true
    ) if is_ci

    signing_args = is_ci ? ci_signing_xcargs : ""
    archive_path = "./build/LazerDragon.xcarchive"

    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      clean: true,
      xcargs: signing_args,
      skip_package_ipa: true,
      archive_path: archive_path
    )

    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      export_method: "app-store",
      output_directory: "./build",
      archive_path: archive_path,
      skip_build_archive: true
    )

    upload_to_app_store(
      api_key: api_key,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  # ── Utilities ────────────────────────────────────────

  desc "Register new device UDIDs"
  lane :register_devices_from_file do
    register_devices(devices_file: "./fastlane/devices.txt")
  end

  desc "Sync code signing certificates"
  lane :sync_signing do
    UI.message("Configure match in Matchfile when ready for automated signing")
  end

end
